# ═══════════════════════════════════════════════════════════
# SOLANA QUANT PLATFORM - ENVIRONMENT VARIABLES
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql://solana_quant:solana_quant@localhost:5432/solana_quant

# Redis
REDIS_URL=redis://localhost:6379/0

# Binance (no API key needed for public data)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# CoinGecko (free demo key - register at coingecko.com)
COINGECKO_API_KEY=

# Telegram Bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert Settings
MIN_CONFIDENCE=50
SIGNAL_COOLDOWN_SECONDS=3600
MAX_SIGNALS_PER_DAY=10

# ML Settings
ML_RETRAIN_INTERVAL_HOURS=168
MODEL_PATH=./backend/ml/models

# Server
API_HOST=0.0.0.0
API_PORT=8000
